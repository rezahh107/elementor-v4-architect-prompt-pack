{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rezahh107/elementor-v4-architect-prompt-pack/schemas/ev4-builder-context-package.schema.json",
  "title": "EV4 Builder Context Package",
  "$defs": {
    "element_generation": { "enum": ["V4 Atomic Element", "V3 element", "Shared compatibility element", "Unverified element type"] },
    "element_generation_source": { "enum": ["architect_export", "builder_context_package", "elementor_ui_screenshot", "user_statement", "versioned_documentation", "unverified"] }
  },
  "type": "object",
  "required": ["schema", "source_stage", "source_handoff_stage", "package_status", "selected_candidate_id", "selected_candidate_locked", "production_ready_allowed", "source_payload_ledger", "approved_structure_tree", "class_creation_application_map", "widget_mapping_table", "editable_content_map", "decoration_only_map", "asset_replacement_map", "scoped_css_need_map", "responsive_qa_seed", "forbidden_work", "first_builder_batch", "confirmation_request"],
  "properties": {
    "schema": { "const": "ev4-builder-context-package@1.0.0" },
    "source_stage": { "const": "/builder-feed-export" },
    "source_handoff_stage": { "const": "/handoff-export" },
    "package_status": { "enum": ["ready", "ready_with_visible_flags", "blocked"] },
    "selected_candidate_id": { "type": "string", "minLength": 1 },
    "selected_candidate_locked": { "const": true },
    "production_ready_allowed": { "const": false },
    "source_payload_ledger": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "reference_screenshot_instruction": { "type": "object" },
    "approved_structure_tree": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "class_creation_application_map": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "widget_mapping_table": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "editable_content_map": { "type": "array", "items": { "type": "object" } },
    "decoration_only_map": { "type": "array", "items": { "type": "object" } },
    "asset_replacement_map": { "type": "array", "items": { "type": "object" } },
    "scoped_css_need_map": { "type": "array", "items": { "type": "object" } },
    "responsive_qa_seed": { "type": "object", "required": ["unresolved_breakpoints", "connector_behavior_status", "meaningful_content_visibility_rule"] },
    "audit_flags_to_preserve": { "type": "array", "items": { "type": "string" } },
    "unknowns_to_preserve": { "type": "array", "items": { "type": "string" } },
    "forbidden_work": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "first_builder_batch": {
      "type": "object",
      "required": ["max_actions", "actions"],
      "properties": {
        "max_actions": { "type": "integer", "minimum": 1, "maximum": 5 },
        "actions": { "type": "array", "minItems": 1, "maxItems": 5, "items": { "type": "object", "required": ["action_id"] } }
      }
    },
    "confirmation_request": {
      "type": "object",
      "required": ["confirmation_id", "confirmed_action_ids", "expected_user_token", "template_id"],
      "properties": {
        "confirmation_id": { "type": "string" },
        "confirmed_action_ids": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
        "expected_user_token": { "type": "string", "minLength": 1 },
        "template_id": { "const": "standard_batch_confirmation" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
